---
export const prerender = false;

type PopulationCount = {
  year: string;
  value: string;
  sex?: string;
  reliabilty?: string;
};

type CityPopulation = {
  city: string;
  country: string;
  populationCounts: PopulationCount[];
};

type ApiResponse = {
  error: boolean;
  msg: string;
  data: CityPopulation[];
};

const country = Astro.url.searchParams.get('country')?.trim() ?? '';

let apiMessage = '';
let apiError = '';
let results: CityPopulation[] = [];

if (country) {
  try {
    const response = await fetch('https://countriesnow.space/api/v0.1/countries/population/cities/filter', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        country,
        limit: 10,
        order: 'asc',
        orderBy: 'name',
      }),
    });

    if (!response.ok) {
      throw new Error(`API returned ${response.status}`);
    }

    const payload = (await response.json()) as ApiResponse;

    if (payload.error) {
      apiError = payload.msg || 'API zwrocilo blad.';
    } else {
      apiMessage = payload.msg;
      results = payload.data ?? [];
      if (results.length === 0) {
        apiError = `Brak wynikow dla kraju "${country}".`;
      }
    }
  } catch {
    apiError = 'Nie udalo sie pobrac danych z zewnetrznego API.';
  }
}

const getLatestPopulation = (counts: PopulationCount[]) => {
  const sorted = [...counts].sort((a, b) => Number(b.year) - Number(a.year));
  return sorted[0];
};
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Lookup kraju przez Astro</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #0b1020;
        --bg-2: #111b37;
        --panel: rgba(11, 16, 32, 0.82);
        --panel-border: rgba(255, 255, 255, 0.12);
        --text: #eef2ff;
        --muted: #b8c0e0;
        --accent: #7dd3fc;
        --accent-strong: #38bdf8;
        --success: #34d399;
        --danger: #fb7185;
        --warning: #fbbf24;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(56, 189, 248, 0.22), transparent 34%),
          radial-gradient(circle at 85% 20%, rgba(125, 211, 252, 0.18), transparent 28%),
          linear-gradient(160deg, var(--bg), var(--bg-2));
      }

      main {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 32px 20px;
      }

      .shell {
        width: min(100%, 860px);
        border: 1px solid var(--panel-border);
        border-radius: 28px;
        padding: 28px;
        background: var(--panel);
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.35);
        backdrop-filter: blur(18px);
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(125, 211, 252, 0.12);
        color: var(--accent);
        font-size: 0.9rem;
        letter-spacing: 0.02em;
      }

      h1 {
        margin: 18px 0 12px;
        font-size: clamp(2.4rem, 6vw, 4.7rem);
        line-height: 0.95;
        letter-spacing: -0.05em;
      }

      p {
        margin: 0;
        color: var(--muted);
        max-width: 58ch;
        line-height: 1.6;
      }

      .grid {
        display: grid;
        gap: 20px;
        grid-template-columns: 1.1fr 0.9fr;
        margin-top: 28px;
      }

      form,
      .card {
        border-radius: 22px;
        border: 1px solid var(--panel-border);
        background: rgba(255, 255, 255, 0.03);
      }

      form {
        padding: 22px;
      }

      .card {
        padding: 22px;
      }

      label {
        display: block;
        margin-bottom: 14px;
        font-weight: 600;
      }

      input,
      button {
        width: 100%;
        margin-top: 8px;
        border-radius: 14px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(7, 10, 18, 0.6);
        color: var(--text);
        font: inherit;
      }

      input {
        padding: 14px 16px;
      }

      button {
        margin-top: 6px;
        padding: 14px 18px;
        border: 0;
        cursor: pointer;
        font-weight: 700;
        background: linear-gradient(135deg, var(--accent-strong), #22c55e);
        color: #03111d;
      }

      button:hover {
        filter: brightness(1.03);
      }

      .status {
        margin: 18px 0 0;
        padding: 14px 16px;
        border-radius: 16px;
        font-weight: 600;
      }

      .status.success {
        background: rgba(52, 211, 153, 0.12);
        color: var(--success);
      }

      .status.error {
        background: rgba(251, 113, 133, 0.12);
        color: var(--danger);
      }

      .status.info {
        background: rgba(251, 191, 36, 0.12);
        color: var(--warning);
      }

      .meta {
        display: grid;
        gap: 14px;
        margin-top: 18px;
      }

      .meta div {
        padding: 14px 16px;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.04);
        color: var(--muted);
        line-height: 1.5;
      }

      .meta strong {
        display: block;
        color: var(--text);
        margin-bottom: 4px;
      }

      .results {
        display: grid;
        gap: 14px;
        margin-top: 18px;
      }

      .results article {
        padding: 16px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
      }

      .results h2 {
        margin: 0 0 8px;
        font-size: 1.1rem;
      }

      .results p + p {
        margin-top: 8px;
      }

      @media (max-width: 820px) {
        .grid {
          grid-template-columns: 1fr;
        }

        .shell {
          padding: 20px;
          border-radius: 22px;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <section class="shell">
        <span class="eyebrow">Astro + server-side fetch</span>
        <h1>Wyszukaj kraj i pokaz miasta</h1>
        <p>Uzytkownik podaje kraj, Astro odpytuje zewnetrzne API po stronie serwera i wyswietla przefiltrowane miasta z populacja.</p>

        {!country && <p class="status info">Wpisz nazwe kraju, np. Poland, Nigeria albo Japan.</p>}
        {apiMessage && <p class="status success">{apiMessage}</p>}
        {apiError && <p class="status error">{apiError}</p>}

        <div class="grid">
          <form action="/" method="get">
            <label>
              Kraj
              <input
                type="text"
                name="country"
                value={country}
                placeholder="Np. Poland"
                autocomplete="country-name"
              />
            </label>

            <button type="submit">Pobierz wynik</button>
          </form>

          <aside class="card">
            <p>Ten test nie wysyla maili. Zamiast tego backend Astro pobiera dane z dokumentowanego endpointu i renderuje wynik HTML.</p>
            <div class="meta">
              <div>
                <strong>Endpoint</strong>
                POST https://countriesnow.space/api/v0.1/countries/population/cities/filter
              </div>
              <div>
                <strong>Payload</strong>
                country, limit, order, orderBy
              </div>
              <div>
                <strong>Filtrowanie</strong>
                Limit 10 rekordow, sortowanie rosnaco po nazwie miasta
              </div>
            </div>
          </aside>
        </div>

        {results.length > 0 && (
          <section class="results">
            {results.map((item) => {
              const latest = getLatestPopulation(item.populationCounts);

              return (
                <article>
                  <h2>{item.city}</h2>
                  <p>
                    <strong>Kraj:</strong> {item.country}
                  </p>
                  <p>
                    <strong>Najnowsza populacja:</strong> {latest ? `${latest.value} (${latest.year})` : 'brak danych'}
                  </p>
                </article>
              );
            })}
          </section>
        )}
      </section>
    </main>
  </body>
</html>
